{
    "scopeName" : "source.dsl_lira",
    "fileTypes" : ["dsl_lira"],
    "name"      : "dsl_lira",
    "patterns"  : [ {"include": "#line"} ],
    "repository": {
        "line": {
            "begin"        : "^(\\d+)([A-Za-z]*)\\s+",
            "beginCaptures": { "1": {"name": "entity.name.type"}, "2": {"name": "keyword.other"} },
            "end"          : ";?$",
            "patterns"     : [
                {
                    "name"    : "meta.outputs",
                    "begin"   : "(?=\\d)",
                    "end"     : "(?=\\s*=)",
                    "patterns": [
                        {"match": "\\d+", "name": "constant.numeric"},
                        {"match": "\\w+", "name": "variable.other"  }
                    ]
                },
                {
                    "match"   : "=\\s+(\\S+)\\s+(\\S+)",
                    "captures": { "1": {"name": "keyword.other"}, "2": {"name": "entity.name.type"} }
                },
                {"match": "\\w+", "name": "variable.other"}
            ]
        }
    }
}
